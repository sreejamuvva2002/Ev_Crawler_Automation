# Required for Gemini runs
GEMINI_API_KEY=your_gemini_api_key

# Optional model overrides
GEMINI_MODEL=gemini-2.5-flash
QWEN_MODEL=qwen3:8b
GEMMA_MODEL=gemma3:12b
OLLAMA_BASE_URL=http://localhost:11434

# Optional judge-based evaluation overrides
EVALUATION_JUDGE_PROVIDER=ollama
EVALUATION_JUDGE_MODEL=mistral-small3.2:24b
EVALUATION_MAX_RETRIES=2

# Legacy compatibility aliases still supported by load_config()
# RAGAS_JUDGE_PROVIDER=ollama
# RAGAS_JUDGE_MODEL=mistral-small3.2:24b
# RAGAS_MAX_RETRIES=2
